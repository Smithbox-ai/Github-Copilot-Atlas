# ── Node.js ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.pnpm-store/

# ── Plans (work-in-progress documents, not for public) ────
# Ignore all plan files by default, but allow required project artifacts
plans/*
!plans/project-context.md
!plans/pipeline-comparison.md
!plans/session-outcomes.md
!plans/templates/
plans/templates/*
!plans/templates/gate-event-template.md
!plans/templates/phase-completion-template.md
!plans/templates/plan-document-template.md
!plans/templates/session-outcome-template.md
!plans/templates/verified-items-template.md

# ── Tutorial docs ────────────────────────────────────────
# docs/tutorial-ru/
# docs/tutorial-en/

# ── Agent internal state (session scratchpad) ─────────────
# NOTES.md is a required project artifact tracked in the repository
# AGENTS.md is a local-only working-notes helper for AI agents
AGENTS.md
Agent.md

# ── Secrets & credentials ─────────────────────────────────
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.secret

# ── Logs ──────────────────────────────────────────────────
logs/
*.log

# ── Build & temp artifacts ────────────────────────────────
dist/
build/
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo
# ── Eval warm cache ────────────────────────────────────────────
evals/.cache/
# ── Tool output spill directory ───────────────────────────────
.cache/tool-output/
# ── Windows OS artifacts ──────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── macOS OS artifacts ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ── VS Code user-specific settings ───────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace
package-release.bat
