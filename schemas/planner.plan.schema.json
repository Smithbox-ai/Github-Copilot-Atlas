{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/planner.plan.schema.json",
  "title": "PlannerPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent",
    "status",
    "task_title",
    "summary",
    "confidence",
    "abstain",
    "phases",
    "open_questions",
    "risks",
    "risk_review",
    "success_criteria",
    "complexity_tier",
    "handoff"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.2.0" },
    "trace_id": {
      "type": "string",
      "format": "uuid",
      "description": "Optional UUIDv4 for cross-agent trace correlation."
    },
    "agent": { "type": "string", "const": "Planner" },
    "status": {
      "type": "string",
      "enum": ["READY_FOR_EXECUTION", "ABSTAIN", "REPLAN_REQUIRED"]
    },
    "task_title": { "type": "string", "minLength": 3 },
    "summary": { "type": "string", "minLength": 10 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "abstain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_abstaining", "reasons"],
      "properties": {
        "is_abstaining": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase_id",
          "title",
          "objective",
          "wave",
          "executor_agent",
          "files",
          "tests",
          "steps",
          "acceptance_criteria",
          "quality_gates"
        ],
        "properties": {
          "phase_id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 3 },
          "objective": { "type": "string", "minLength": 5 },
          "wave": {
            "type": "integer",
            "minimum": 1,
            "description": "Execution wave for parallel dispatch. Phases in the same wave run in parallel. Wave N+1 waits for wave N to complete."
          },
          "executor_agent": {
            "type": "string",
            "enum": [
              "CodeMapper-subagent",
              "Researcher-subagent",
              "CoreImplementer-subagent",
              "UIImplementer-subagent",
              "PlatformEngineer-subagent",
              "TechnicalWriter-subagent",
              "BrowserTester-subagent",
              "CodeReviewer-subagent"
            ],
            "description": "Primary subagent Orchestrator must dispatch for this phase. Orchestrator treats this field as authoritative and must not override it with heuristics."
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 },
            "description": "Phase IDs that must complete before this phase can start."
          },
          "failure_expectations": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["scenario", "classification", "mitigation"],
              "properties": {
                "scenario": { "type": "string" },
                "classification": {
                  "type": "string",
                  "enum": ["transient", "fixable", "needs_replan", "escalate", "model_unavailable"]
                },
                "mitigation": { "type": "string" }
              }
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "action", "reason"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "action": {
                  "type": "string",
                  "enum": ["create", "modify", "review", "reference"]
                },
                "reason": { "type": "string", "minLength": 3 }
              }
            }
          },
          "tests": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "quality_gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["tests_pass", "lint_clean", "schema_valid", "safety_clear", "human_approved_if_required"]
            }
          },
          "skill_references": {
            "type": "array",
            "items": { "type": "string" },
            "description": "File paths to relevant skill patterns from the skills library."
          }
        }
      }
    },
    "contracts": {
      "type": "array",
      "description": "Inter-phase contracts defining producer/consumer relationships between dependent phases.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_phase", "to_phase", "interface", "format"],
        "properties": {
          "from_phase": { "type": "integer", "minimum": 1, "description": "Producer phase ID" },
          "to_phase": { "type": "integer", "minimum": 1, "description": "Consumer phase ID" },
          "interface": { "type": "string", "description": "What the producer provides to the consumer" },
          "format": { "type": "string", "description": "Data format, schema, or contract specification" }
        }
      }
    },
    "max_parallel_agents": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 10,
      "description": "Maximum number of subagents Orchestrator may dispatch in parallel within a single wave."
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "options", "recommendation"],
        "properties": {
          "question": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } },
          "recommendation": { "type": "string" }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "mitigation"],
        "properties": {
          "risk": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "risk_review": {
      "type": "array",
      "description": "Mandatory semantic risk checklist. Planner must evaluate every category before plan finalization. Non-applicable categories must still be listed with applicability: not_applicable.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "applicability", "impact", "evidence_source", "disposition"],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["data_volume", "performance", "concurrency", "access_control", "migration_rollback", "dependency", "operability"]
          },
          "applicability": {
            "type": "string",
            "enum": ["applicable", "not_applicable", "uncertain"]
          },
          "evidence_source": {
            "type": "string",
            "description": "File path, query, or external source that supports the applicability assessment."
          },
          "impact": {
            "type": "string",
            "enum": ["HIGH", "MEDIUM", "LOW", "UNKNOWN"]
          },
          "disposition": {
            "type": "string",
            "enum": ["resolved", "open_question", "research_phase_added", "not_applicable"]
          }
        }
      }
    },
    "success_criteria": { "type": "array", "items": { "type": "string" } },
    "diagrams": {
      "type": "array",
      "description": "Mermaid architecture diagrams. Required when phases array has 3 or more items.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title", "mermaid_source"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["flowchart", "sequenceDiagram", "stateDiagram-v2"],
            "description": "Mermaid diagram type. flowchart for dependency DAG, sequenceDiagram for inter-phase flow, stateDiagram-v2 for state machines."
          },
          "title": { "type": "string", "minLength": 3 },
          "mermaid_source": { "type": "string", "minLength": 10, "description": "Raw Mermaid source code for the diagram." }
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_agent", "prompt"],
      "properties": {
        "target_agent": { "type": "string" },
        "prompt": { "type": "string" }
      }
    },
    "complexity_tier": {
      "type": "string",
      "enum": ["TRIVIAL", "SMALL", "MEDIUM", "LARGE"],
      "description": "Task complexity classification. Determines pipeline depth: TRIVIAL skips plan review, SMALL uses lite review, MEDIUM/LARGE use full review pipeline."
    },
    "iteration_budget": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "default": 5,
      "description": "Maximum plan-review iterations before escalation to user."
    },
    "revision_of": {
      "type": "string",
      "description": "Path of the prior plan artifact this plan supersedes. Set on REPLAN-with-new-plan-path events so the new plan is traceable to its predecessor. Optional — iter-1 plans omit this field."
    }
  }
}