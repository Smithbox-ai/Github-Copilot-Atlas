{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://copilot-atlas.local/schemas/devops.execution-report.schema.json",
  "title": "DevOpsExecutionReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent",
    "status",
    "confidence",
    "abstain",
    "scope",
    "changes",
    "health_checks",
    "deployment_details",
    "approval_gates_passed",
    "tests",
    "build",
    "lint",
    "dependencies",
    "definition_of_done",
    "next_steps"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "agent": { "type": "string", "const": "DevOps-subagent" },
    "status": { "type": "string", "enum": ["COMPLETE", "NEEDS_INPUT", "FAILED", "ABSTAIN"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "failure_classification": {
      "type": "string",
      "enum": ["transient", "fixable", "needs_replan", "escalate"],
      "description": "Required when status is FAILED or NEEDS_INPUT. Classifies the failure type for Atlas retry/escalation logic."
    },
    "clarification_request": {
      "$ref": "clarification-request.schema.json",
      "description": "Required when status is NEEDS_INPUT. Structured payload for Atlas to present to user via askQuestions. See schemas/clarification-request.schema.json for full contract."
    },
    "abstain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_abstaining", "reasons"],
      "properties": {
        "is_abstaining": { "type": "boolean" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "action", "summary"],
        "properties": {
          "file": { "type": "string" },
          "action": { "type": "string", "enum": ["create", "modify", "delete"] },
          "summary": { "type": "string" }
        }
      }
    },
    "health_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "state"],
        "properties": {
          "service": { "type": "string" },
          "state": { "type": "string", "enum": ["HEALTHY", "UNHEALTHY", "NOT_AVAILABLE"] },
          "details": { "type": "string" }
        }
      }
    },
    "resource_usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu": { "type": "string" },
        "memory": { "type": "string" },
        "disk": { "type": "string" },
        "details": { "type": "string" }
      }
    },
    "deployment_details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment", "state"],
      "properties": {
        "environment": { "type": "string", "enum": ["development", "staging", "production"] },
        "state": { "type": "string", "enum": ["DEPLOYED", "ROLLED_BACK", "FAILED", "NOT_APPLICABLE"] },
        "version": { "type": "string" },
        "timestamp": { "type": "string" },
        "details": { "type": "string" }
      }
    },
    "approval_gates_passed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["production_approval", "security_approval", "none_required"]
      }
    },
    "rollback_steps_taken": {
      "type": "array",
      "description": "Required when status is FAILED. Lists steps taken to revert environment to pre-deployment state.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "result"],
        "properties": {
          "step": { "type": "string" },
          "result": { "type": "string", "enum": ["SUCCESS", "FAILED", "SKIPPED"] },
          "details": { "type": "string" }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["individual", "full_suite"],
      "properties": {
        "individual": { "type": "string", "enum": ["PASS", "FAIL", "NOT_RUN"] },
        "full_suite": { "type": "string", "enum": ["PASS", "FAIL", "NOT_RUN"] },
        "details": { "type": "string" }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "type": "string", "enum": ["PASS", "FAIL", "NOT_AVAILABLE", "NOT_RUN"] },
        "details": { "type": "string" }
      }
    },
    "lint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "type": "string", "enum": ["PASS", "FAIL", "NOT_AVAILABLE", "NOT_RUN"] },
        "details": { "type": "string" }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "reason"],
        "properties": {
          "name": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "definition_of_done": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_items_complete", "unchecked_items"],
      "properties": {
        "all_items_complete": { "type": "boolean" },
        "unchecked_items": { "type": "array", "items": { "type": "string" } }
      }
    },
    "next_steps": { "type": "array", "items": { "type": "string" } }
  }
}
