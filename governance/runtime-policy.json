{
  "_comment": "Orchestrator operational knobs only. Scoring thresholds live in docs/agent-engineering/SCORING-SPEC.md. File-count complexity boundaries live in plans/project-context.md.",

  "approval_required_actions": [
    "destructive_file_delete",
    "bulk_contract_rewrite",
    "git_force_push",
    "git_reset_hard",
    "drop_table",
    "rm_rf",
    "amend_published_commit",
    "merge_to_protected_branch",
    "push_to_shared_infrastructure"
  ],

  "review_pipeline_by_tier": {
    "TRIVIAL": {
      "plan_auditor": false,
      "assumption_verifier": false,
      "executability_verifier": false,
      "code_review": true
    },
    "SMALL": {
      "plan_auditor": true,
      "assumption_verifier": false,
      "executability_verifier": false,
      "code_review": true
    },
    "MEDIUM": {
      "plan_auditor": true,
      "assumption_verifier": true,
      "executability_verifier": false,
      "code_review": true
    },
    "LARGE": {
      "plan_auditor": true,
      "assumption_verifier": true,
      "executability_verifier": true,
      "code_review": true
    }
  },

  "max_iterations_by_tier": {
    "TRIVIAL": 2,
    "SMALL": 2,
    "MEDIUM": 5,
    "LARGE": 5
  },

  "retry_budgets": {
    "max_retries_per_phase": 5,
    "transient_max": 3,
    "fixable_max": 1,
    "needs_replan_max": 1,
    "escalate_max": 0,
    "per_wave_transient_reduction_threshold": 2,
    "per_wave_parallelism_reduction_factor": 0.5
  },

  "stagnation_detection": {
    "same_phase_failure_escalation_threshold": 3,
    "same_classification_repeat_escalation": true
  },

  "session_telemetry": {
    "template": "plans/templates/session-outcome-template.md",
    "log_file": "plans/session-outcomes.md",
    "write_timing": "before_completion_summary",
    "archive_threshold_entries": 50
  },

  "tool_output_policy": {
    "spill_directory_template": ".cache/tool-output/<task-slug>/",
    "task_slug_pattern": "^[a-zA-Z0-9_-]+$",
    "purge_timing": "completion_gate_only",
    "max_total_mb": null
  },

  "plan_review_gate_trigger_conditions": {
    "min_phases": 3,
    "confidence_threshold": 0.9,
    "high_risk_scope_triggers_review": true,
    "applicable_high_impact_risk_triggers_review": true
  },

  "batch_approval": {
    "approval_per": "wave",
    "exception_destructive_phases": "per_phase"
  },

  "budget_defaults": {
    "enabled": false,
    "token_cap": null,
    "wall_clock_s": null,
    "cost_usd": null,
    "enable_reflection": false,
    "notes": "Orthogonal to retry_budgets. Reaching a budget cap classifies as 'escalate', not a failed attempt."
  },

  "final_review_gate": {
    "enabled_by_default": false,
    "auto_trigger_tiers": ["LARGE"],
    "allow_user_trigger": true,
    "max_fix_cycles": 1
  }
}
