{
  "id": "code-reviewer-final-scope-clean",
  "target_agent": "CodeReviewer-subagent",
  "goal": "Final-scope review with review_scope=final returns valid verdict with final_review_summary and empty out_of_scope_changes",
  "input": {
    "task": "Holistic final review of all phases after plan completion",
    "phase_id": 0,
    "review_scope": "final",
    "changed_files": ["src/auth.ts", "src/api.ts"],
    "plan_phases_snapshot": [
      { "phase_id": 1, "files": ["src/auth.ts"] },
      { "phase_id": 2, "files": ["src/api.ts"] }
    ]
  },
  "expected": {
    "schema": "schemas/code-reviewer.verdict.schema.json",
    "required_status": ["APPROVED", "NEEDS_REVISION", "FAILED", "ABSTAIN"],
    "must_include": [
      "review_scope",
      "final_review_summary",
      "changed_files_analysis",
      "validated_blocking_issues"
    ],
    "final_scope_invariants": {
      "review_scope_value": "final",
      "out_of_scope_changes_empty": true
    }
  }
}
